(set-logic QF_BV)

; ============================================================
; Compact 5x5 4-bit MDS verifier
; Full path coefficients from 5_5.py:path_4bit are embedded
; Final matrix is precomputed, then all minors are checked non-zero
; Field: GF(2^4)/(x^4 + x + 1)
; ============================================================

; Full fixed path:
; step 01: Type-3 (1,3) coefficient L^-1 = #b1001
; step 02: Type-3 (4,0) coefficient L^1 = #b0010
; step 03: Type-3 (0,1) coefficient L^0 = #b0001
; step 04: Type-2 row 0 coefficient L^-1 = #b1001
; step 05: Type-3 (3,4) coefficient L^0 = #b0001
; step 06: Type-2 row 4 coefficient L^1 = #b0010
; step 07: Type-3 (2,3) coefficient L^0 = #b0001
; step 08: Type-3 (1,2) coefficient L^3 = #b1000
; step 09: Type-2 row 2 coefficient L^-1 = #b1001
; step 10: Type-3 (4,0) coefficient L^-1 = #b1001
; step 11: Type-3 (3,1) coefficient L^0 = #b0001
; step 12: Type-3 (0,3) coefficient L^0 = #b0001
; step 13: Type-3 (2,4) coefficient L^0 = #b0001
; step 14: Type-3 (3,2) coefficient L^0 = #b0001
; step 15: Type-3 (4,0) coefficient L^0 = #b0001

; GF(2^4) multiplication: modulo x^4 + x + 1
(define-fun xtime ((x (_ BitVec 4))) (_ BitVec 4)
  (bvxor (bvshl x #b0001) (ite (= ((_ extract 3 3) x) #b1) #b0011 #b0000))
)

(define-fun gf_mul ((x (_ BitVec 4)) (y (_ BitVec 4))) (_ BitVec 4)
  (bvxor
    (bvxor
      (ite (= ((_ extract 0 0) y) #b1) x #b0000)
      (ite (= ((_ extract 1 1) y) #b1) (xtime x) #b0000))
    (bvxor
      (ite (= ((_ extract 2 2) y) #b1) (xtime (xtime x)) #b0000)
      (ite (= ((_ extract 3 3) y) #b1) (xtime (xtime (xtime x))) #b0000)))
)

