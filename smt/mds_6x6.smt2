; GF(2^8) multiplication: modulo x^8 + x^7 + x^2 + x + 1
(define-fun xtime ((x (_ BitVec 8))) (_ BitVec 8)
  (bvxor (bvshl x #x01) (ite (= ((_ extract 7 7) x) #b1) #x87 #x00))
)

(define-fun gf_mul ((x (_ BitVec 8)) (y (_ BitVec 8))) (_ BitVec 8)
  (bvxor
    (bvxor
      (bvxor
        (bvxor
          (ite (= ((_ extract 0 0) y) #b1) x #x00)
          (ite (= ((_ extract 1 1) y) #b1) (xtime x) #x00))
        (bvxor
          (ite (= ((_ extract 2 2) y) #b1) (xtime (xtime x)) #x00)
          (ite (= ((_ extract 3 3) y) #b1) (xtime (xtime (xtime x))) #x00)))
      (bvxor
        (ite (= ((_ extract 4 4) y) #b1) (xtime (xtime (xtime (xtime x)))) #x00)
        (ite (= ((_ extract 5 5) y) #b1) (xtime (xtime (xtime (xtime (xtime x))))) #x00)))
    (bvxor
      (ite (= ((_ extract 6 6) y) #b1) (xtime (xtime (xtime (xtime (xtime (xtime x)))))) #x00)
      (ite (= ((_ extract 7 7) y) #b1) (xtime (xtime (xtime (xtime (xtime (xtime (xtime x))))))) #x00)))
)

